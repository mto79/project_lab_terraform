# Example remote state backends — copy to backend.tf and fill in values.
# Only ONE backend block should be active at a time.

# ── S3 (AWS) ────────────────────────────────────────────────────────────────
# terraform {
#   backend "s3" {
#     bucket         = "my-terraform-state"
#     key            = "project_lab/terraform.tfstate"
#     region         = "eu-west-1"
#     encrypt        = true
#     dynamodb_table = "terraform-lock"
#   }
# }

